# Postgres
POSTGRES_USER=callmor
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=callmor
DATABASE_URL=postgres://callmor:CHANGE_ME@127.0.0.1:5432/callmor

# Redis
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379

# MinIO
MINIO_ROOT_USER=callmor
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=http://127.0.0.1:9000

# coturn
TURN_SECRET=CHANGE_ME
TURN_REALM=callmor.ai

# JWT signing secret (HS256). Generate with: openssl rand -hex 32
# Must be at least 32 chars. Same value must be used by API and relay.
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG

# Server ports
RELAY_PORT=8080
API_PORT=3000

# Public URL of the web frontend (used in emails)
PUBLIC_WEB_URL=https://remote.callmor.ai

# SMTP (optional — invitations work without it via copy-paste link)
# For Mail-in-a-Box: use your box hostname, port 587, STARTTLS
#SMTP_HOST=box.yourdomain.com
#SMTP_PORT=587
#SMTP_USERNAME=noreply@yourdomain.com
#SMTP_PASSWORD=your-mailbox-password
#SMTP_TLS=starttls
#SMTP_FROM_EMAIL=noreply@yourdomain.com
#SMTP_FROM_NAME=Callmor Remote
