[Unit]
Description=Callmor Relay Server (WebSocket Signaling)
After=network-online.target docker.service postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=pasharobert
WorkingDirectory=/home/pasharobert/callmor-remote-desktop
EnvironmentFile=/home/pasharobert/callmor-remote-desktop/.env
ExecStart=/home/pasharobert/callmor-remote-desktop/target/release/callmor-relay
Restart=always
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=callmor-relay

[Install]
WantedBy=multi-user.target
